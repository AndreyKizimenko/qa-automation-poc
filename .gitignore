# Claude Code local settings
.claude/settings.local.json

# Logs
*.log

# Playwright MCP browser-tooling artifacts: page snapshots and console
# logs captured during interactive exploration. May contain DOM dumps
# of the live QA instance (host names, emails, etc.) — never commit.
.playwright-mcp/

# Playwright-suite ignores live in playwright/.gitignore

# Loadtest specs are local-only (per-run credentials, not committed).
# Scoped to playwright/tests/ so we don't shadow playwright/pages/ paths.
playwright/tests/loadtest/