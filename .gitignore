# OS / editor junk
.DS_Store
.AppleDouble
.LSOverride
Icon
._*
.DocumentRevisions-V100
.fseventsd
.Spotlight-V100
.TemporaryItems
.Trashes
*.swp
*.swo

# Claude Code local settings
.claude/settings.local.json
# Repo-root harness state (scheduled-task locks, etc.). Keep
# playwright/.claude/ checked in — that's the shared skills tree.
/.claude/

# Logs
*.log

# Playwright MCP browser-tooling artifacts: page snapshots and console
# logs captured during interactive exploration. May contain DOM dumps
# of the live QA instance (host names, emails, etc.) — never commit.
.playwright-mcp/

# Playwright-suite ignores live in playwright/.gitignore

# Output of gitops/loadtest/generate.sh — bulk yml/scripts/profiles/etc.
# regenerated locally before each loadtest run. Only the generator script
# is checked in.
gitops/loadtest/generated/