{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "types": ["node", "@playwright/test"],
    "paths": {
      "@fixtures": ["./fixtures.ts"],
      "@helpers/*": ["./helpers/*"],
      "@pages": ["./pages/index.ts"],
      "@pages/*": ["./pages/*"]
    }
  },
  "include": [
    "playwright.config.ts",
    "fixtures.ts",
    "setup/**/*.ts",
    "helpers/**/*.ts",
    "pages/**/*.ts",
    "tests/**/*.ts"
  ]
}
