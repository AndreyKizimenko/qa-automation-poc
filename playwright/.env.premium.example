# ── Fleet instance ───────────────────────────────────────────────────────────
FLEET_URL=https://your-premium-instance.example.com
FLEET_API_TOKEN=

# ── Admin (Playwright login + setup) ─────────────────────────────────────────
FLEET_ADMIN_EMAIL=
FLEET_ADMIN_PASSWORD=

# ── Test user credentials (User-management specs) ────────────────────────────
# Password used for every test user the User-management specs create.
# Must satisfy Fleet's policy: 12-48 characters with at least 1 number and
# 1 symbol. The accounts are torn down per spec and by cleanup.steps.ts.
FLEET_TEST_USER_PASSWORD=

# ── GitOps apply (fleetctl gitops -f gitops/premium-fleetqa/default.yml ...) ─
# Premium has enroll secrets managed via the UI (gitops checkbox unchecked),
# so FLEET_ENROLL_SECRET is not needed here — only on free.
FLEET_SSO_METADATA_URL=
FLEET_EUA_METADATA_URL=
FLEET_ABM_ORG_NAME=
FLEET_VPP_LOCATION=

# ── Admin SSO login spec ─────────────────────────────────────────────────────
# Admin SSO is assumed to be pre-configured on the instance. These credentials
# are an IdP test user (JIT-provisionable on first sign-in).
FLEET_SSO_LOGIN_USERNAME=
FLEET_SSO_LOGIN_PASSWORD=

# ── Static users (role-access + My Account specs) ────────────────────────────
# Shared password used by every human static user defined in
# helpers/api/static-users.ts. Same policy as FLEET_TEST_USER_PASSWORD.
FLEET_STATIC_USER_PASSWORD=

# Bearer tokens captured at user-creation time for each API-only static
# user. Generated by `npm run provision:static-users:premium` — copy the
# script's output block here and into GitHub secrets. Tokens are one-shot
# and cannot be rotated; delete and re-provision a user to refresh.
FLEET_STATIC_TOKEN_API_GLOBAL_ADMIN=
FLEET_STATIC_TOKEN_API_GLOBAL_MAINTAINER=
FLEET_STATIC_TOKEN_API_GLOBAL_OBSERVER=
FLEET_STATIC_TOKEN_API_GLOBAL_OBSERVER_PLUS=
FLEET_STATIC_TOKEN_API_GLOBAL_TECHNICIAN=
FLEET_STATIC_TOKEN_API_GLOBAL_GITOPS=
FLEET_STATIC_TOKEN_API_WS_MAINTAINER=
FLEET_STATIC_TOKEN_API_WS_OBSERVER=
FLEET_STATIC_TOKEN_API_WS_MAINT_QA_OBS=
FLEET_STATIC_TOKEN_API_SPECIFIC_ENDPOINTS_GLOBAL=
FLEET_STATIC_TOKEN_API_SPECIFIC_ENDPOINTS_WS=
