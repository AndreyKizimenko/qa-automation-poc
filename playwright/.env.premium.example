# ── Fleet instance ───────────────────────────────────────────────────────────
FLEET_URL=https://your-premium-instance.example.com
FLEET_API_TOKEN=

# ── Admin (Playwright login + setup) ─────────────────────────────────────────
FLEET_ADMIN_EMAIL=
FLEET_ADMIN_PASSWORD=

# ── GitOps apply (fleetctl gitops -f gitops/premium-fleetqa/default.yml ...) ─
# Premium has enroll secrets managed via the UI (gitops checkbox unchecked),
# so FLEET_ENROLL_SECRET is not needed here — only on free.
FLEET_SSO_METADATA_URL=
FLEET_EUA_METADATA_URL=
FLEET_ABM_ORG_NAME=
FLEET_VPP_LOCATION=

# ── Admin SSO login spec ─────────────────────────────────────────────────────
# Admin SSO is assumed to be pre-configured on the instance. These credentials
# are an IdP test user (JIT-provisionable on first sign-in).
FLEET_SSO_LOGIN_USERNAME=
FLEET_SSO_LOGIN_PASSWORD=
